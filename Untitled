import faiss
import pickle
import numpy as np
import requests
from sentence_transformers import SentenceTransformer

# Load index
index = faiss.read_index("gita.index")

with open("verses.pkl", "rb") as f:
    verses = pickle.load(f)

embedder = SentenceTransformer("all-MiniLM-L6-v2")

OLLAMA_URL = "http://localhost:11434/api/generate"
MODEL_NAME = "tinyllama"

def retrieve(query, k=5):
    query_embedding = embedder.encode([query])
    D, I = index.search(np.array(query_embedding), k)
    return [verses[i] for i in I[0]]

def generate_response(query):
    retrieved = retrieve(query)

    context = "\n\n".join(
        [f"Chapter {v['chapter']} Verse {v['verse']}: {v['text']}" for v in retrieved]
    )

    prompt = f"""
You are Lord Krishna from the Bhagavad Gita.
Speak with calm authority and compassion.
Base your answer strictly on the verses provided.

Context:
{context}

Question:
{query}

Answer:
"""

    response = requests.post(
        OLLAMA_URL,
        json={
            "model": MODEL_NAME,
            "prompt": prompt,
            "stream": False
        }
    )

    return response.json()["response"]